{
  "manifest_version": 3,
  "name": "AudioBookBay Magnet Assistant",
  "description": "Creates magnet links for AudioBookBay pages without logging in.",
  "icons": {
    "16": "./icons/extension_icon16.png",
    "32": "./icons/extension_icon32.png",
    "48": "./icons/extension_icon48.png",
    "128": "./icons/extension_icon128.png"
  },
  "version": "4.0.0",
  "permissions": [
    "clipboardWrite",
    "clipboardRead",
    "storage"
  ],
  "host_permissions": [
    "*://*.audiobookbay.lu/*",
    "*://*.audiobookbay.li/*",
    "*://*.audiobookbay.fi/*",
    "*://*.audiobookbay.nl/*",
    "*://*.audiobookbay.is/*",
    "*://*.audiobookbay.se/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.audiobookbay.lu/*",
        "*://*.audiobookbay.li/*",
        "*://*.audiobookbay.fi/*",
        "*://*.audiobookbay.nl/*",
        "*://*.audiobookbay.is/*",
        "*://*.audiobookbay.se/*"
      ],
      "js": [
        "abbma.js"
      ],
      "css": [
        "abbma.css"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{16ec1e5b-2ec8-4186-89fb-ca8f548d6178}",
      "strict_min_version": "109.0"
    }
  }
}